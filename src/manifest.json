{
  "manifest_version": 3,
  "name": "Copy Jira issue ID",
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "icons": {
    "128": "img/icon128.png"
  },
  "content_scripts": [
    {
      "js": [
        "content/index.js"
      ],
      "matches": [
        "*://*.atlassian.net/*"
      ]
    }
  ],
  "permissions": [
    "contextMenus",
    "tabs",
    "scripting",
    "clipboardRead",
    "clipboardWrite"
  ],
  "host_permissions": [
    "*://*.atlassian.net/*"
  ],
  "action": {
    "default_popup": "pages/popup/index.html"
  }
}
